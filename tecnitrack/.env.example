# TecniTrack - Variables de entorno
# Copiar como .env y completar los valores

SECRET_KEY=django-insecure-reemplazar-con-clave-segura-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.tecnitrack.cl

# PostgreSQL (OBLIGATORIO - django-tenants no funciona con SQLite)
DB_NAME=tecnitrack
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Produccion: cambiar EMAIL_BACKEND en settings.py
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=notificaciones@tecnitrack.cl
EMAIL_HOST_PASSWORD=app-password-de-gmail

SITE_URL=http://localhost:8000
